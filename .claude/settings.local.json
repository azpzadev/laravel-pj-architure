{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__search-docs",
      "Bash(php artisan:*)",
      "Bash(vendor/bin/pint --dirty --format agent)",
      "Bash(php -l app/Domain/Auth/Actions/IssueApiTokenAction.php app/Domain/Auth/Actions/RevokeCurrentTokenAction.php app/Domain/Auth/DataTransferObjects/LoginCredentials.php app/Domain/Auth/DataTransferObjects/IssuedToken.php app/Domain/Auth/Exceptions/InvalidCredentialsException.php app/Http/Controllers/Api/AuthController.php app/Http/Requests/Api/LoginRequest.php app/Http/Resources/IssuedTokenResource.php)",
      "Bash(git init:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git -c user.email=you@example.com -c user.name=you commit -m ':*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
